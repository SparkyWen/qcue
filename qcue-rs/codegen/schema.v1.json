          "start_line": {
            "type": "integer",
            "format": "uint32",
            "minimum": 0.0
          }
        },
        "additionalProperties": false
      },
      "DreamPhase": {
        "type": "string",
        "enum": [
          "Orient",
          "Gather",
          "Consolidate",
          "Prune"
        ]
      },
      "WikiEditOp": {
        "description": "CANONICAL (serde tag=\"type\"). `Merge` carries the target slug; S3/app-server-protocol IMPORTS this. `schemars::JsonSchema` is derived here (additive, non-breaking) so the canonical type can be embedded in `app-server-protocol::Item` (which codegens its JSON-Schema for Dart — Master §8).",
        "oneOf": [
          {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "Create"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "Update"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "into_slug",
              "type"
            ],
            "properties": {
              "into_slug": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "Merge"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "Delete"
                ]
              }
            }
          }
        ]
      }
    }
  },
