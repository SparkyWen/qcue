{
  "AppReleaseManifest": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AppReleaseManifest",
    "description": "AU-R7 — the app release manifest (`GET /v1/app/release?platform=…`). Global, non-tenant, no secrets. `latest_build`/`min_supported_build` are the integer `pubspec.yaml` build numbers the client compares against its own. `android_apk_path` (Android only) points at the JWT-authenticated proxy `/v1/app/apk/{build}`; `ios_app_store_url` (iOS only) is the App Store deep link.",
    "type": "object",
    "required": [
      "changelog",
      "latest_build",
      "latest_version",
      "min_supported_build",
      "platform",
      "published_at"
    ],
    "properties": {
      "android_apk_path": {
        "type": [
          "string",
          "null"
        ]
      },
      "android_apk_sha256": {
        "description": "Android only — the expected SHA-256 (lowercase hex) of the APK served at `android_apk_path`, so the client can verify the sideloaded download's integrity (tamper/MITM detection). None ⇒ the server has no hash on file (older manifest) and the client treats it as unverified.",
        "default": null,
        "type": [
          "string",
          "null"
        ]
      },
      "changelog": {
        "type": "string"
      },
      "ios_app_store_url": {
        "type": [
          "string",
          "null"
        ]
      },
      "latest_build": {
        "type": "integer",
        "format": "uint32",
        "minimum": 0.0
      },
      "latest_version": {
        "type": "string"
      },
      "min_supported_build": {
        "type": "integer",
        "format": "uint32",
        "minimum": 0.0
      },
      "platform": {
        "type": "string"
      },
      "published_at": {
        "type": "string"
      }
    }
  },
  "CaptureDetail": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CaptureDetail",
    "description": "The full detail of one capture (GET /v1/captures/{id}) — CAP-R1.",
    "type": "object",
    "required": [
      "body",
      "captured_at",
      "id",
      "ingest_state",
      "kind",
      "origin"
    ],
    "properties": {
      "body": {
        "type": "string"
      },
      "captured_at": {
        "type": "string"
      },
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "ingest_state": {
        "type": "string"
      },
      "kind": {
        "type": "string"
      },
      "lat": {
        "type": [
          "number",
          "null"
        ],
        "format": "double"
      },
      "lng": {
        "type": [
          "number",
          "null"
        ],
        "format": "double"
      },
      "loc_accuracy_m": {
        "type": [
          "number",
          "null"
        ],
        "format": "float"
      },
      "origin": {
        "type": "string"
      },
      "source_page_slug": {
        "description": "The slug of the distilled SOURCE page (DIG-R4), if this capture has been ingested. None ⇒ pending.",
        "type": [
          "string",
          "null"
        ]
      },
      "source_url": {
        "type": [
          "string",
          "null"
        ]
      }
    }
  },
  "CaptureParams": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CaptureParams",
    "type": "object",
    "required": [
      "kind",
      "origin"
    ],
    "properties": {
      "body": {
        "default": null,
        "type": [
          "string",
          "null"
        ]
      },
      "captured_at": {
        "description": "LOC-R3/Part F — the client's action-time capture instant (RFC3339 UTC). None ⇒ server now().",
        "default": null,
        "type": [
          "string",
          "null"
        ]
      },
      "kind": {
        "type": "string"
      },
      "lat": {
        "description": "LOC-R1 — optional precise location captured at action-time (off by default).",
        "default": null,
        "type": [
          "number",
          "null"
        ],
        "format": "double"
      },
      "lng": {
        "default": null,
        "type": [
          "number",
          "null"
        ],
        "format": "double"
      },
      "loc_accuracy_m": {
        "default": null,
        "type": [
          "number",
          "null"
        ],
        "format": "float"
      },
      "origin": {
        "type": "string"
      },
      "source_url": {
        "default": null,
        "type": [
          "string",
          "null"
        ]
      }
    },
    "additionalProperties": false
  },
  "CapturePatch": {
    "$schema": "http://json-schema.org/draft-07/schema#",
