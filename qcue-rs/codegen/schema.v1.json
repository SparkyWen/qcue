    "properties": {
      "idea_id": {
        "type": "string",
        "format": "uuid"
      },
      "ingest_job_id": {
        "type": "string",
        "format": "uuid"
      }
    }
  },
  "ConversationMessage": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ConversationMessage",
    "description": "REC-R6/REC-D7 — one persisted turn in `GET /v1/conversations/{thread}/messages`. `role` is `\"user\"|\"assistant\"` (no tool/system turns are persisted); `content` is the redacted final text.",
    "type": "object",
    "required": [
      "content",
      "role"
    ],
    "properties": {
      "content": {
        "type": "string"
      },
      "role": {
        "type": "string"
      }
    }
  },
  "ConversationSummary": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ConversationSummary",
    "description": "REC-R6/REC-D7 — one row in `GET /v1/conversations` (the recall history drawer). Serde-only.",
    "type": "object",
    "required": [
      "id",
      "title",
      "updated_at"
    ],
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "last_snippet": {
        "default": null,
        "type": [
          "string",
          "null"
        ]
      },
      "title": {
        "type": "string"
      },
      "updated_at": {
        "description": "RFC3339 UTC; the client formats it locally (the wire never carries a local clock).",
        "type": "string"
      }
    }
  },
  "IngestRunResult": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "IngestRunResult",
    "description": "DIG-R5 — the result of `POST /v1/ingest/run` (the one-click incremental digest): how many per-idea ingest jobs were enqueued, and their ids (so the client can poll `GET /v1/jobs/{id}` for progress). Repeated clicks collapse onto existing pending jobs (debounce), so `enqueued` counts distinct dirty ideas, not new rows.",
    "type": "object",
    "required": [
      "enqueued",
      "job_ids"
    ],
    "properties": {
      "enqueued": {
        "type": "integer",
        "format": "uint32",
        "minimum": 0.0
      },
      "job_ids": {
        "type": "array",
        "items": {
          "type": "string",
          "format": "uuid"
        }
      }
    }
  },
  "InitializeParams": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "InitializeParams",
    "type": "object",
    "properties": {
      "opt_out_notification_methods": {
        "default": [],
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "schema_version": {
        "default": 0,
        "type": "integer",
        "format": "uint16",
        "minimum": 0.0
      }
    },
    "additionalProperties": false
  },
