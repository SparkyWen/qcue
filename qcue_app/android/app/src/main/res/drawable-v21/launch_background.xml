<?xml version="1.0" encoding="utf-8"?>
<!-- Modify this file to customize your launch splash screen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="?android:colorBackground" />

    <!-- QCue brand mark centered on the launch window, mirroring the iOS
         LaunchScreen (brand tile centered). Uses the adaptive-icon foreground
         raster (~108dp across density buckets). colorBackground adapts to the
         OS dark-mode setting, matching the app's Clean Light / Night themes. -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
